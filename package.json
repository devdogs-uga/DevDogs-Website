    "argon2": "^0.44.0",
    "bcrypt": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "discord-api-types": "^0.38.49",
    "discord-interactions": "^4.4.0",
    "drizzle-orm": "1.0.0-rc.3",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.21.0",
    "motion": "^12.40.0",
