{
  "name": "@devdogsuga/docs-preview",
  "version": "0.1.0",
  "description": "Local documentation preview server for DevDogs projects",
  "bin": {
    "docs-preview": "./dist/server.js"
  },
  "exports": {
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    }
  },
  "typesVersions": {
    "*": {
      "client": [
        "./dist/client.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "chokidar": "^4",
    "ws": "^8"
  },
  "devDependencies": {
    "@types/node": "*",
    "@types/react": "*",
    "@types/ws": "^8",
    "typescript": "*"
  }
}
