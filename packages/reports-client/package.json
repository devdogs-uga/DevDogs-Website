{
  "name": "@devdogsuga/reports-client",
  "version": "0.1.0",
  "description": "Client SDK for the DevDogs content-reporting API",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./webhook": {
      "types": "./dist/webhook.d.ts",
      "default": "./dist/webhook.js"
    }
  },
  "typesVersions": {
    "*": {
      ".": [
        "./dist/index.d.ts"
      ],
      "webhook": [
        "./dist/webhook.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "devDependencies": {
    "@types/node": "*",
    "typescript": "*"
  }
}
