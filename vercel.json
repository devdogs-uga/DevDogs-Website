{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "git": {
    "deploymentEnabled": false
  },
  "crons": [
    {
      "path": "/api/github/sync-leaderboard",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/deliver-webhooks",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/sync-discord-roles",
      "schedule": "*/10 * * * *"
    }
  ]
}
